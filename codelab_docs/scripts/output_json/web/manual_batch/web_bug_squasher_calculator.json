            "buggyCode": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Simple Calculator</title>\n    <style>\n        body {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            margin: 0;\n            font-family: sans-serif;\n            background: #ecf0f1;\n        }\n\n        .calc {\n            background: #34495e;\n            padding: 20px;\n            border-radius: 10px;\n        }\n\n        #display {\n            width: 100%;\n            height: 50px;\n            font-size: 1.5rem;\n            text-align: right;\n            margin-bottom: 10px;\n            background: #fff;\n            border: none;\n            padding: 10px;\n            box-sizing: border-box;\n        }\n\n        .buttons {\n            display: grid;\n            grid-template-columns: repeat(4, 1fr);\n            gap: 5px;\n        }\n\n        button {\n            padding: 15px;\n            font-size: 1.1rem;\n            border: none;\n            background: #95a5a6;\n            cursor: pointer;\n            border-radius: 5px;\n        }\n\n        button:hover {\n            background: #bdc3c7;\n        }\n\n        .equal {\n            grid-column: span 2;\n            background: #e67e22;\n            color: white;\n        }\n\n        .clear {\n            background: #e74c3c;\n            color: white;\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"calc\">\n        <input type=\"text\" id=\"display\" disabled>\n        <div class=\"buttons\">\n            <button onclick=\"clearDisplay()\" class=\"clear\">C</button>\n            <button onclick=\"appendToDisplay('/')\">/</button>\n            <button onclick=\"appendToDisplay('*')\">*</button>\n            <button onclick=\"appendToDisplay('-')\">-</button>\n            <button onclick=\"appendToDisplay('7')\">7</button>\n            <button onclick=\"appendToDisplay('8')\">8</button>\n            <button onclick=\"appendToDisplay('9')\">9</button>\n            <button onclick=\"appendToDisplay('+')\">+</button>\n            <button onclick=\"appendToDisplay('4')\">4</button>\n            <button onclick=\"appendToDisplay('5')\">5</button>\n            <button onclick=\"appendToDisplay('6')\">6</button>\n            <button onclick=\"calculate()\" class=\"equal\">=</button>\n            <button onclick=\"appendToDisplay('1')\">1</button>\n            <button onclick=\"appendToDisplay('2')\">2</button>\n            <button onclick=\"appendToDisplay('3')\">3</button>\n            <button onclick=\"appendToDisplay('0')\">0</button>\n        </div>\n    </div>\n\n    <script>\n        const display = document.find('display');\n        function appendToDisplay(value) { display.value += value; }\n        function clearDisplay() { display.value = ''; }\n        function calculate() {\n            try {\n                display.value = eval(display.value);\n            } catch {\n                display.value = 'Error';\n            }\n        }\n    </script>\n</body>\n\n</html>",
            "solution": {
                "code": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Simple Calculator</title>\n    <style>\n        body {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            margin: 0;\n            font-family: sans-serif;\n            background: #ecf0f1;\n        }\n\n        .calc {\n            background: #34495e;\n            padding: 20px;\n            border-radius: 10px;\n        }\n\n        #display {\n            width: 100%;\n            height: 50px;\n            font-size: 1.5rem;\n            text-align: right;\n            margin-bottom: 10px;\n            background: #fff;\n            border: none;\n            padding: 10px;\n            box-sizing: border-box;\n        }\n\n        .buttons {\n            display: grid;\n            grid-template-columns: repeat(4, 1fr);\n            gap: 5px;\n        }\n\n        button {\n            padding: 15px;\n            font-size: 1.1rem;\n            border: none;\n            background: #95a5a6;\n            cursor: pointer;\n            border-radius: 5px;\n        }\n\n        button:hover {\n            background: #bdc3c7;\n        }\n\n        .equal {\n            grid-column: span 2;\n            background: #e67e22;\n            color: white;\n        }\n\n        .clear {\n            background: #e74c3c;\n            color: white;\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"calc\">\n        <input type=\"text\" id=\"display\" disabled>\n        <div class=\"buttons\">\n            <button onclick=\"clearDisplay()\" class=\"clear\">C</button>\n            <button onclick=\"appendToDisplay('/')\">/</button>\n            <button onclick=\"appendToDisplay('*')\">*</button>\n            <button onclick=\"appendToDisplay('-')\">-</button>\n            <button onclick=\"appendToDisplay('7')\">7</button>\n            <button onclick=\"appendToDisplay('8')\">8</button>\n            <button onclick=\"appendToDisplay('9')\">9</button>\n            <button onclick=\"appendToDisplay('+')\">+</button>\n            <button onclick=\"appendToDisplay('4')\">4</button>\n            <button onclick=\"appendToDisplay('5')\">5</button>\n            <button onclick=\"appendToDisplay('6')\">6</button>\n            <button onclick=\"calculate()\" class=\"equal\">=</button>\n            <button onclick=\"appendToDisplay('1')\">1</button>\n            <button onclick=\"appendToDisplay('2')\">2</button>\n            <button onclick=\"appendToDisplay('3')\">3</button>\n            <button onclick=\"appendToDisplay('0')\">0</button>\n        </div>\n    </div>\n\n    <script>\n        const display = document.getElementById('display');\n        function appendToDisplay(value) { display.value += value; }\n        function clearDisplay() { display.value = ''; }\n        function calculate() {\n            try {\n                display.value = eval(display.value);\n            } catch {\n                display.value = 'Error';\n            }\n        }\n    </script>\n</body>\n\n</html>",
