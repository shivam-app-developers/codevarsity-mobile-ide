                "code": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Simple Image Slider</title>\n    <style>\n        body {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            margin: 0;\n            background: #f0f0f0;\n        }\n\n        .slider {\n            position: relative;\n            width: 600px;\n            height: 400px;\n            overflow: hidden;\n            border-radius: 10px;\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);\n        }\n\n        .slides {\n            display: flex;\n            width: 300%;\n            height: 100%;\n            transition: transform 0.5s ease;\n        }\n\n        .slide {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 3rem;\n            color: white;\n        }\n\n        .slide1 {\n            background: #e74c3c;\n        }\n\n        .slide2 {\n            background: #3498db;\n        }\n\n        .slide3 {\n            background: #2ecc71;\n        }\n\n        .nav-btn {\n            position: absolute;\n            top: 50%;\n            transform: translateY(-50%);\n            background: rgba(255, 255, 255, 0.7);\n            border: none;\n            padding: 10px;\n            cursor: pointer;\n            border-radius: 50%;\n        }\n\n        .prev {\n            left: 10px;\n        }\n\n        .next {\n            right: 10px;\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"slider\">\n        <div class=\"slides\" id=\"slides\">\n            <div class=\"slide slide1\">Slide 1</div>\n            <div class=\"slide slide2\">Slide 2</div>\n            <div class=\"slide slide3\">Slide 3</div>\n        </div>\n        <button class=\"nav-btn prev\" id=\"prevBtn\">\u276e</button>\n        <button class=\"nav-btn next\" id=\"nextBtn\">\u276f</button>\n    </div>\n\n    <script>\n        const slides = document.getElementById('slides');\n        const next = document.getElementById('nextBtn');\n        const prev = document.getElementById('prevBtn');\n        let index = 0;\n\n        function updateSlider() {\n            slides.style.transform = `translateX(${-index * 100 / 3}%)`;\n        }\n\n        next.addEventListener('click', () => {\n            index = (index + 1) % 3;\n            updateSlider();\n        });\n\n        prev.addEventListener('click', () => {\n            index = (index - 1 + 3) % 3;\n            updateSlider();\n        });\n    </script>\n</body>\n\n</html>",
