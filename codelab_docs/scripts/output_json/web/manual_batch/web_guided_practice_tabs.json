            "ghostCode": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Tabbed Content</title>\n    <style>\n        body {\n            font-family: sans-serif;\n            padding: 20px;\n            display: flex;\n            justify-content: center;\n        }\n\n        .tabs {\n            width: 300px;\n        }\n\n        .tabs-header {\n            display: flex;\n            background: #ddd;\n        }\n\n        .tab-btn {\n            flex: 1;\n            padding: 10px;\n            cursor: pointer;\n            text-align: center;\n        }\n\n        .tab-btn.active {\n            background: #3498db;\n            color: white;\n        }\n\n        .tab-content {\n            display: none;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-top: none;\n        }\n\n        .tab-content.active {\n            display: block;\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"tabs\">\n        <div class=\"tabs-header\">\n            <div class=\"tab-btn active\" data-tab=\"tab1\">Home</div>\n            <div class=\"tab-btn\" data-tab=\"tab2\">Info</div>\n            <div class=\"tab-btn\" data-tab=\"tab3\">Contact</div>\n        </div>\n        <div class=\"tab-content active\" id=\"tab1\">Welcome to the homepage.</div>\n        <div class=\"tab-content\" id=\"tab2\">Here is some more info.</div>\n        <div class=\"tab-content\" id=\"tab3\">Get in touch with us!</div>\n    </div>\n\n    <script>\n        const btns = document.querySelectorAll('.tab-btn');\n        const contents = document.querySelectorAll('.tab-content');\n\n        btns.forEach(btn => {\n            btn.addEventListener('click', () => {\n                btns.forEach(b => b.classList.remove('active'));\n                contents.forEach(c => c.classList.remove('active'));\n\n                btn.classList.add('active');\n                document.getElementById(btn.dataset.tab).classList.add('active');\n            });\n        });\n    </script>\n</body>\n\n</html>",
            "finalCode": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Tabbed Content</title>\n    <style>\n        body {\n            font-family: sans-serif;\n            padding: 20px;\n            display: flex;\n            justify-content: center;\n        }\n\n        .tabs {\n            width: 300px;\n        }\n\n        .tabs-header {\n            display: flex;\n            background: #ddd;\n        }\n\n        .tab-btn {\n            flex: 1;\n            padding: 10px;\n            cursor: pointer;\n            text-align: center;\n        }\n\n        .tab-btn.active {\n            background: #3498db;\n            color: white;\n        }\n\n        .tab-content {\n            display: none;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-top: none;\n        }\n\n        .tab-content.active {\n            display: block;\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"tabs\">\n        <div class=\"tabs-header\">\n            <div class=\"tab-btn active\" data-tab=\"tab1\">Home</div>\n            <div class=\"tab-btn\" data-tab=\"tab2\">Info</div>\n            <div class=\"tab-btn\" data-tab=\"tab3\">Contact</div>\n        </div>\n        <div class=\"tab-content active\" id=\"tab1\">Welcome to the homepage.</div>\n        <div class=\"tab-content\" id=\"tab2\">Here is some more info.</div>\n        <div class=\"tab-content\" id=\"tab3\">Get in touch with us!</div>\n    </div>\n\n    <script>\n        const btns = document.querySelectorAll('.tab-btn');\n        const contents = document.querySelectorAll('.tab-content');\n\n        btns.forEach(btn => {\n            btn.addEventListener('click', () => {\n                btns.forEach(b => b.classList.remove('active'));\n                contents.forEach(c => c.classList.remove('active'));\n\n                btn.classList.add('active');\n                document.getElementById(btn.dataset.tab).classList.add('active');\n            });\n        });\n    </script>\n</body>\n\n</html>",
