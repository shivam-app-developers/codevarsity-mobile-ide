       if (!isActive) item.classList.add('active');\n            });\n        });\n    </script>\n</body>\n\n</html>",
            "solution": {
                "code": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Accordion UI</title>\n    <style>\n        body {\n            font-family: sans-serif;\n            display: flex;\n            justify-content: center;\n            padding-top: 50px;\n        }\n\n        .accordion {\n            width: 350px;\n        }\n\n        .item {\n            border-bottom: 1px solid #ccc;\n        }\n\n        .header {\n            background: #f4f4f4;\n            padding: 15px;\n            cursor: pointer;\n            display: flex;\n            justify-content: space-between;\n            font-weight: bold;\n        }\n\n        .content {\n            display: none;\n            padding: 15px;\n            background: white;\n            color: #555;\n        }\n\n        .active .content {\n            display: block;\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"accordion\">\n        <div class=\"item\">\n            <div class=\"header\">Section 1 <span>+</span></div>\n            <div class=\"content\">Content for section 1 goes here. It provides more detail.</div>\n        </div>\n        <div class=\"item\">\n            <div class=\"header\">Section 2 <span>+</span></div>\n            <div class=\"content\">Information about section 2 is displayed when expanded.</div>\n        </div>\n        <div class=\"item\">\n            <div class=\"header\">Section 3 <span>+</span></div>\n            <div class=\"content\">Final details for the third section of the accordion.</div>\n        </div>\n    </div>\n\n    <script>\n        const items = document.querySelectorAll('.item');\n        items.forEach(item => {\n            item.querySelector('.header').addEventListener('click', () => {\n                const isActive = item.classList.contains('active');\n                items.forEach(i => i.classList.remove('active'));\n                if (!isActive) item.classList.add('active');\n            });\n        });\n    </script>\n</body>\n\n</html>",
                "explanation": "Fixed the incorrect method call or syntax error."
